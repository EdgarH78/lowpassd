# Gemini
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro

# Storage — S3-compatible. Defaults target local MinIO via docker-compose.
# For GCS in prod: set S3_ENDPOINT=https://storage.googleapis.com, S3_FORCE_PATH_STYLE=false,
# and use HMAC interop keys (https://cloud.google.com/storage/docs/aws-simple-migration).
S3_ENDPOINT=http://localhost:9100
S3_REGION=us-east-1
S3_ACCESS_KEY=lowpassd
S3_SECRET_KEY=lowpassd-secret
S3_FORCE_PATH_STYLE=true
BUCKET_RAW=lowpassd-raw
BUCKET_ARCHIVE=lowpassd-archive
BUCKET_WIKI=lowpassd-wiki

# Orchestrator
CRON_SCHEDULE=0 */6 * * *
MAX_LOOKBACK_DAYS=7
RUN_ON_START=true

# Server
PORT=8080
