{
  "name": "lowpassd",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "cycle": "tsx src/cli.ts cycle",
    "ingest": "tsx src/cli.ts ingest",
    "compile": "tsx src/cli.ts compile"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@hono/node-server": "^1.13.7",
    "dotenv": "^16.4.5",
    "hono": "^4.6.14",
    "marked": "^14.1.4",
    "node-cron": "^3.0.3",
    "rss-parser": "^3.13.0",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/node-cron": "^3.0.11",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
